# Enma — sitio estático (Next.js export) servido en Apache/cPanel (Namecheap).
# Next copia este archivo a out/.htaccess en cada build.

# Página 404 propia (en el export estático es 404.html en la raíz).
ErrorDocument 404 /404.html

# Las imágenes Open Graph de next/og se exportan SIN extensión (archivos
# llamados "opengraph-image"). Forzamos su tipo MIME a PNG para que los
# previews de WhatsApp/redes las reconozcan como imagen.
<FilesMatch "^opengraph-image$">
  ForceType image/png
</FilesMatch>

# Link headers — exponen relaciones útiles a crawlers y agentes sin que tengan
# que parsear el HTML: el sitemap XML y el feed RSS del blog.
<IfModule mod_headers.c>
  Header set Link "</sitemap.xml>; rel=\"sitemap\", </feed.xml>; rel=\"alternate\"; type=\"application/rss+xml\""

  # ── Cabeceras de seguridad (recomendaciones de Lighthouse) ──────────────────
  # Solo las seguras para un export estático de Next: NO añadimos una CSP que
  # restrinja scripts/estilos ni Trusted Types, porque Next sirve scripts/estilos
  # inline (hydration) y sin nonces/hashes los bloquearía → rompería el sitio.
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Cross-Origin-Opener-Policy "same-origin"
</IfModule>

# El feed RSS de next/og/route se exporta como archivo "feed.xml" (con extensión);
# Apache ya lo sirve, pero fijamos el MIME por si acaso.
<FilesMatch "^feed\.xml$">
  ForceType application/rss+xml
</FilesMatch>
